{
  "expo": {
    "name": "Artmarket",
    "slug": "artmarket",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "artmarket",
    "platforms": ["ios", "android"],
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.artmarket.app"
    },
    "android": {
      "package": "com.artmarket.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "TBD"
      }
    }
  }
}
